# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Local development (SQLite):
# DATABASE_URL="file:./dev.db"

# Docker development (PostgreSQL — matches docker-compose.yml defaults):
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/restaurants

# Onboarding Configuration
BATCH_SIZE=10

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# resend
RESEND_API_KEY=
EMAIL_FROM=Mi Orden <noreply@appmiorden.com>

# Timezone (IANA name — Node.js uses this for all Date operations)
TZ=America/Argentina/Buenos_Aires

# JWT
JWT_SECRET=

# Port (optional, defaults to 3000)
PORT=3000

# Upload storage
UPLOAD_STORAGE=local
UPLOAD_CF_R2_ACCOUNT_ID=
UPLOAD_CF_R2_ACCESS_KEY_ID=
UPLOAD_CF_R2_SECRET_ACCESS_KEY=
UPLOAD_CF_R2_BUCKET_NAME=
UPLOAD_CF_R2_PUBLIC_URL=

# OpenTelemetry — distributed tracing
# Desactivar completamente (no se generan ni exportan trazas):
# OTEL_SDK_DISABLED=true
# Local (Jaeger via docker-compose.otel.yml):
OTEL_SERVICE_NAME=api-core
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318/v1/traces
# Sampling: 0.1 = 10% bajo load testing; 1.0 para debugging puntual
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1   # 10% bajo load testing; 1.0 para debugging puntual
# Producción (Grafana Cloud):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://<stack>.grafana.net/otlp/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-token>
