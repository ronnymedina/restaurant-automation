flowchart TD
    A([POST /v1/onboarding/register]) --> B{¿Email ya existe?}
    B -- Sí --> ERR1[409 EMAIL_ALREADY_EXISTS]
    B -- No --> C[/$transaction/\nCrear restaurante\nCrear usuario MANAGER\nCrear categoría default]
    C -- Error --> ERR2[500 · rollback total]
    C -- OK --> D{¿Tiene photos?}
    D -- Sí --> E[Extraer productos con Gemini AI]
    E -- Error/vacío --> F[0 productos · continúa]
    E -- OK --> G[Filtrar precio > 0\ncreatProductsBatch]
    D -- No --> H{createDemoData?}
    H -- true --> I[5 productos demo\nMenú Principal\nPlatos Principales + Bebidas]
    H -- false --> J[0 productos]
    G --> K[Enviar email activación\n⚠ no bloqueante]
    F --> K
    I --> K
    J --> K
    K --> L([201 · productsCreated])

    style ERR1 fill:#fee2e2,stroke:#ef4444,color:#7f1d1d
    style ERR2 fill:#fee2e2,stroke:#ef4444,color:#7f1d1d
    style K fill:#fef9c3,stroke:#eab308,color:#713f12
    style L fill:#dcfce7,stroke:#22c55e,color:#14532d
