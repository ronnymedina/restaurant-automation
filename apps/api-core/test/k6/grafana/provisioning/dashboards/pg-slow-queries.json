      "title": "Queries más lentas (ordenadas por tiempo total acumulado)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
          "rawQuery": true,
          "rawSql": "SELECT\n  left(query, 100) AS query,\n  calls,\n  round(total_exec_time::numeric, 2) AS total_ms,\n  round(mean_exec_time::numeric, 2) AS avg_ms,\n  rows\nFROM pg_stat_statements\nORDER BY total_exec_time DESC\nLIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
