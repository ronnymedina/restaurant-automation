---
export const prerender = true;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold text-slate-800">Pantalla de Cocina</h2>
    <p class="text-slate-500">Genera un enlace de acceso para la pantalla de cocina. Comparte la URL con el personal — no requiere inicio de sesión.</p>

    <div id="kitchenCard" class="bg-white rounded-xl border border-slate-200 p-6">
      <p class="text-slate-400 text-center">Cargando...</p>
    </div>

    <!-- Modal fecha de vencimiento -->
    <div id="expiryModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl w-full max-w-sm p-6 space-y-4">
        <h3 class="text-lg font-bold text-slate-800">Fecha de vencimiento</h3>
        <p class="text-sm text-slate-500">El acceso dejará de funcionar después de esta fecha.</p>
        <div class="space-y-1">
          <label for="expiryDate" class="text-sm font-medium text-slate-700">Vence el</label>
          <input id="expiryDate" type="date"
                 class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div class="flex gap-3 pt-1">
          <button id="cancelExpiry"
                  class="flex-1 py-2 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50 cursor-pointer bg-transparent">
            Cancelar
          </button>
          <button id="confirmExpiry"
                  class="flex-1 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 cursor-pointer border-none">
            Generar
          </button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { apiFetch } from '../../lib/api';

  const card = document.getElementById('kitchenCard')!;
  const expiryModal = document.getElementById('expiryModal')!;
  const expiryDateInput = document.getElementById('expiryDate') as HTMLInputElement;
  const cancelExpiryBtn = document.getElementById('cancelExpiry')!;
  const confirmExpiryBtn = document.getElementById('confirmExpiry')!;

  // Default: 60 days from today
  function defaultExpiryValue() {
    const d = new Date();
    d.setDate(d.getDate() + 60);
    return d.toISOString().split('T')[0];
  }

  // Minimum: tomorrow
  function minExpiryValue() {
    const d = new Date();
    d.setDate(d.getDate() + 1);
    return d.toISOString().split('T')[0];
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('es', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  function openExpiryModal() {
    expiryDateInput.min = minExpiryValue();
    expiryDateInput.value = defaultExpiryValue();
    expiryModal.classList.remove('hidden');
  }

  cancelExpiryBtn.addEventListener('click', () => {
    expiryModal.classList.add('hidden');
  });

  confirmExpiryBtn.addEventListener('click', async () => {
    const expiresAt = expiryDateInput.value;
    if (!expiresAt) return;
    expiryModal.classList.add('hidden');
    await doGenerateToken(expiresAt);
  });

  function renderWithToken(kitchenUrl: string, expiresAt: string) {
    const fullUrl = `${window.location.origin}${kitchenUrl}`;
    card.innerHTML = `
      <div class="space-y-4">
        <div class="flex items-start gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
          <div class="w-2.5 h-2.5 mt-1.5 rounded-full bg-green-500 shrink-0"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-semibold text-green-700 uppercase tracking-wider mb-1">Acceso activo</p>
            <a href="${kitchenUrl}" target="_blank"
               class="text-sm text-indigo-600 hover:text-indigo-800 break-all">${fullUrl}</a>
          </div>
          <button id="copyKitchenUrl" title="Copiar URL"
                  class="shrink-0 p-1.5 text-slate-400 hover:text-indigo-600 bg-transparent border-none cursor-pointer rounded">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </div>
        <p class="text-xs text-slate-400">Vence el <span class="font-medium text-slate-600">${formatDate(expiresAt)}</span></p>
        <button id="regenerateBtn"
                class="px-4 py-2 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50 cursor-pointer bg-transparent">
          Regenerar acceso
        </button>
      </div>
    `;
    document.getElementById('copyKitchenUrl')!.addEventListener('click', () => {
      navigator.clipboard.writeText(fullUrl);
      const btn = document.getElementById('copyKitchenUrl')!;
      btn.title = '¡Copiado!';
      setTimeout(() => { btn.title = 'Copiar URL'; }, 2000);
    });
    document.getElementById('regenerateBtn')!.addEventListener('click', openExpiryModal);
  }

  function renderEmpty() {
    card.innerHTML = `
      <div class="text-center space-y-4 py-4">
        <div class="text-5xl">🍳</div>
        <h3 class="text-lg font-semibold text-slate-700">Sin acceso generado</h3>
        <p class="text-slate-500 text-sm">Genera un enlace para que el personal de cocina pueda ver los pedidos en tiempo real.</p>
        <button id="generateBtn"
                class="px-6 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 cursor-pointer border-none">
          Generar acceso
        </button>
      </div>
    `;
    document.getElementById('generateBtn')!.addEventListener('click', openExpiryModal);
  }

  async function doGenerateToken(expiresAt: string) {
    card.innerHTML = '<p class="text-slate-400 text-center py-4">Generando...</p>';
    try {
      const res = await apiFetch('/v1/kitchen/token/generate', {
        method: 'POST',
        body: JSON.stringify({ expiresAt }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        const msg = err?.message || 'Error al generar el acceso. Intenta de nuevo.';
        card.innerHTML = `<p class="text-red-400 text-center py-4">${Array.isArray(msg) ? msg.join(', ') : msg}</p>`;
        setTimeout(load, 2000);
        return;
      }
      const data = await res.json();
      renderWithToken(data.kitchenUrl, data.expiresAt);
    } catch {
      card.innerHTML = '<p class="text-red-400 text-center py-4">Error de conexión.</p>';
      setTimeout(load, 2000);
    }
  }

  async function load() {
    try {
      const res = await apiFetch('/v1/kitchen/token');
      if (!res.ok) { renderEmpty(); return; }
      const data = await res.json();
      if (data.kitchenUrl) {
        renderWithToken(data.kitchenUrl, data.expiresAt);
      } else {
        renderEmpty();
      }
    } catch {
      renderEmpty();
    }
  }

  load();
</script>
