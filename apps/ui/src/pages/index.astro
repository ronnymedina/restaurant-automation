---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#667eea] to-[#764ba2]">
    <div class="flex flex-col items-center text-center px-4">
      <img src="/favicon-32.png" alt="" width="40" height="40" class="mb-6" />
      <h1 class="text-[3.5rem] font-extrabold text-white leading-tight mb-1">Daikulab</h1>
      <p class="text-sm font-semibold uppercase tracking-widest text-white/60">Restaurant</p>
      <p class="text-lg text-white/70 mt-6 mb-10">Gestión inteligente para tu restaurante</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/login"
          class="px-8 py-3 bg-white text-indigo-600 font-semibold rounded-full hover:bg-white/90 transition-colors"
        >
          Iniciar sesión
        </a>
        <a
          href="/onboarding"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-full hover:bg-white/10 transition-colors"
        >
          Registrarse
        </a>
      </div>
    </div>
  </main>
</Layout>
